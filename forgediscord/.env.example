# ForgeDiscord MVP environment

# Discord
DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=
DISCORD_GUILD_ID=

# Runtime
FORGEDISCORD_ENV=development
FORGEDISCORD_PORT=4205
LOG_LEVEL=info

# OpenClaw / orchestration adapter
OPENCLAW_BASE_URL=
OPENCLAW_API_KEY=
OPENCLAW_DEFAULT_WORKSPACE=internal-projects

# Storage
FORGEDISCORD_DATA_DIR=./data
FORGEDISCORD_AUDIT_DIR=./data/audit
FORGEDISCORD_JOBS_DIR=./data/jobs

# Approval / workflow behavior
DEFAULT_APPROVAL_TIMEOUT_MINUTES=60
DEFAULT_THREAD_AUTOARCHIVE_MINUTES=1440

# Optional future integrations
GITHUB_TOKEN=
POSTGRES_URL=
REDIS_URL=
