      "blockedBy": ["Lock conflict on file src/auth/middleware.ts"],
      "requiresOperatorApproval": false,
      "conflictingLocks": [
        {
          "lockId": "lock-001",
          "type": "file",
          "value": "src/auth/middleware.ts",
          "heldByJobId": "CP-101",
          "mode": "exclusive"
        }
      ],
      "unmetDependencies": [],
      "action": "hold_for_lock",
      "tokenBudgetOk": true,
      "poolCapacityOk": true,
      "approvalWindowOk": true
    },
    "expected": {
      "eligible": false,
      "action": "hold_for_lock",
      "conflictingLocksCount": 1
    }
  },
